<mujoco model="franka grasp scene">
  <!-- Phase 2 scene: official Franka Emika Panda (mujoco_menagerie) + a workbench,
       a graspable part, and a target bin. Real rigid-body physics + contacts.
       Included panda.xml provides the 8 actuators (7 arm position servos + 1
       gripper). Its keyframe was removed so we can add a free-floating part. -->
  <include file="panda.xml"/>

  <statistic center="0.4 0 0.25" extent="0.9"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.4 0.4 0.4" specular="0.1 0.1 0.1"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="140" elevation="-22"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.25 0.35 0.5" rgb2="0.02 0.02 0.05"
      width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4"
      rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5"
      reflectance="0.2"/>
    <material name="part_mat" rgba="0.95 0.55 0.1 1"/>
    <material name="bin_mat" rgba="0.25 0.3 0.38 1"/>
    <material name="bench_mat" rgba="0.45 0.42 0.38 1"/>
  </asset>

  <worldbody>
    <light pos="0.5 0 1.6" dir="0 0 -1" directional="true"/>
    <light pos="0.1 0.5 1.1" dir="0.2 -0.4 -1" diffuse="0.35 0.35 0.35"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- low workbench pad the part rests on (kept thin so the reference grasp
         geometry from menagerie still applies) -->
    <geom name="bench" type="box" pos="0.5 0 0.0025" size="0.18 0.18 0.0025"
      material="bench_mat"/>

    <!-- assembly target bin (where a pick-and-place would deposit the part) -->
    <geom name="bin" type="box" pos="0.45 -0.32 0.03" size="0.06 0.06 0.03"
      material="bin_mat"/>

    <!-- the part to grasp: a free-floating block with high friction -->
    <body name="part" pos="0.5 0 0.035">
      <freejoint name="part_free"/>
      <geom name="part" type="box" size="0.02 0.02 0.03" material="part_mat" mass="0.05"
        friction="1.4 0.06 0.002" condim="4" solref="0.008 1" solimp="0.95 0.99 0.001"/>
    </body>

    <!-- cameras for rendering the demo -->
    <camera name="demo" pos="1.25 -0.95 0.85" xyaxes="0.62 0.78 0 -0.32 0.26 0.91"/>
    <camera name="side" pos="0.5 -1.1 0.5" xyaxes="1 0 0 0 0.4 0.92"/>
    <camera name="top" pos="0.5 0 1.3" xyaxes="1 0 0 0 1 0"/>
  </worldbody>
</mujoco>
